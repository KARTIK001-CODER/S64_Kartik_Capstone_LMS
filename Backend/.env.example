# ── Server ──────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ─────────────────────────────────────────────────────
# Use MongoDB Atlas connection string or local mongodb://localhost:27017/lms
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.ympreqt.mongodb.net/lms?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Frontend ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── LLM / AI ────────────────────────────────────────────────────
# Set to 'true' to use mock responses instead of a real LLM
MOCK_MODE=true

# ── Razorpay ────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ── Cloudinary ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Environment ─────────────────────────────────────────────────
NODE_ENV=development
